<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Pechetruite.com — Catalogue matériel de montage</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Barlow:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
:root {
  --bg:#f5f0e8; --dark:#1c1a14; --cream:#faf7f2; --border:#ddd6c8;
  --green:#4a7c20; --green2:#6aaa30;
  --purple:#5a3a8a; --purple2:#7a5aaa;
  --gold:#c9a84c; --brown:#7a5c1e; --brown2:#a87d30;
  --teal:#1a6a6a; --teal2:#2a9a9a;
  --muted:#8a8272; --text:#252318;
}
*{margin:0;padding:0;box-sizing:border-box;}
html{scroll-behavior:smooth;}
body{font-family:'Barlow',sans-serif;background:var(--bg);color:var(--text);min-height:100vh;overflow-x:hidden;}

header{
  background:var(--dark);padding:16px 40px;
  display:flex;align-items:center;justify-content:space-between;
  position:sticky;top:0;z-index:100;border-bottom:2px solid var(--gold);
}
.brand{font-family:'Playfair Display',serif;font-size:20px;color:#fff;letter-spacing:.02em;}
.brand em{color:var(--gold);font-style:normal;}
.header-nav{display:flex;gap:24px;align-items:center;}
.header-nav a{font-size:12px;color:#888;text-decoration:none;letter-spacing:.15em;text-transform:uppercase;transition:color .15s;}
.header-nav a:hover{color:var(--gold);}

.hero{position:relative;padding:70px 40px 50px;text-align:center;overflow:hidden;}
.hero::before{content:'';position:absolute;inset:0;
  background:radial-gradient(ellipse at 20% 50%,rgba(74,124,32,.07) 0%,transparent 60%),
             radial-gradient(ellipse at 80% 50%,rgba(90,58,138,.07) 0%,transparent 60%);
  pointer-events:none;}
.hero-eyebrow{font-size:11px;letter-spacing:.3em;text-transform:uppercase;color:var(--gold);margin-bottom:18px;animation:fadeUp .6s ease both;}
.hero-title{font-family:'Playfair Display',serif;font-size:clamp(32px,5vw,62px);line-height:1.1;color:var(--dark);margin-bottom:16px;animation:fadeUp .6s .1s ease both;}
.hero-title em{color:var(--green);font-style:italic;}
.hero-sub{font-size:15px;color:var(--muted);font-weight:300;max-width:520px;margin:0 auto 48px;line-height:1.7;animation:fadeUp .6s .2s ease both;}
@keyframes fadeUp{from{opacity:0;transform:translateY(16px);}to{opacity:1;transform:translateY(0);}}

/* ── SECTION TITRE ── */
.section-title{
  font-family:'Playfair Display',serif;font-size:11px;letter-spacing:.3em;
  text-transform:uppercase;color:var(--muted);
  max-width:1100px;margin:0 auto 16px;padding:0 40px;
  display:flex;align-items:center;gap:16px;
}
.section-title::after{content:'';flex:1;height:1px;background:var(--border);}

/* ── GRILLE CARTES ── */
.cards{
  display:grid;
  grid-template-columns:repeat(3,1fr);
  gap:2px;max-width:1100px;
  margin:0 auto 16px;padding:0 40px;
  animation:fadeUp .6s .3s ease both;
}
.cards-2col{grid-template-columns:repeat(2,1fr);}

.card{
  position:relative;background:var(--cream);border:1px solid var(--border);
  border-radius:4px;padding:36px 32px 32px;
  text-decoration:none;color:inherit;
  display:flex;flex-direction:column;gap:16px;overflow:hidden;
  transition:transform .25s,box-shadow .25s;cursor:pointer;
}
.card::before{content:'';position:absolute;top:0;left:0;right:0;height:4px;transition:height .25s;}
.card--green::before{background:var(--green);}
.card--purple::before{background:var(--purple);}
.card--brown::before{background:var(--brown);}
.card--teal::before{background:var(--teal);}
.card--soon{opacity:.55;cursor:default;}
.card--soon::before{background:var(--muted);}
.card:not(.card--soon):hover{transform:translateY(-4px);box-shadow:0 20px 50px rgba(0,0,0,.1);}
.card:not(.card--soon):hover::before{height:6px;}

.card-badge{
  position:absolute;top:14px;right:14px;
  font-size:9px;letter-spacing:.15em;text-transform:uppercase;font-weight:600;
  padding:3px 8px;border-radius:2px;
}
.card--soon .card-badge{background:var(--border);color:var(--muted);}
.card--new .card-badge{background:var(--green);color:#fff;}

.card-icon{width:46px;height:46px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:20px;flex-shrink:0;}
.card--green .card-icon{background:rgba(74,124,32,.1);}
.card--purple .card-icon{background:rgba(90,58,138,.1);}
.card--brown .card-icon{background:rgba(122,92,30,.1);}
.card--teal .card-icon{background:rgba(26,106,106,.1);}
.card--soon .card-icon{background:rgba(0,0,0,.05);}

.card-label{font-size:10px;letter-spacing:.22em;text-transform:uppercase;font-weight:600;}
.card--green .card-label{color:var(--green);}
.card--purple .card-label{color:var(--purple);}
.card--brown .card-label{color:var(--brown);}
.card--teal .card-label{color:var(--teal);}
.card--soon .card-label{color:var(--muted);}

.card-title{font-family:'Playfair Display',serif;font-size:26px;line-height:1.2;color:var(--dark);}
.card-title em{font-style:italic;}
.card-desc{font-size:13px;color:var(--muted);line-height:1.7;font-weight:300;flex:1;}

.card-details{display:flex;flex-direction:column;gap:6px;border-top:1px solid var(--border);padding-top:16px;}
.card-detail{display:flex;align-items:center;gap:8px;font-size:11px;color:var(--muted);}
.card-detail-dot{width:5px;height:5px;border-radius:50%;flex-shrink:0;}
.card--green .card-detail-dot{background:var(--green2);}
.card--purple .card-detail-dot{background:var(--purple2);}
.card--brown .card-detail-dot{background:var(--brown2);}
.card--teal .card-detail-dot{background:var(--teal2);}
.card--soon .card-detail-dot{background:var(--muted);}

.card-cta{
  display:inline-flex;align-items:center;gap:8px;
  padding:11px 20px;border-radius:3px;
  font-size:11px;font-weight:600;letter-spacing:.1em;text-transform:uppercase;
  border:none;cursor:pointer;text-decoration:none;
  transition:opacity .15s,transform .1s;width:fit-content;margin-top:2px;
}
.card--green .card-cta{background:var(--green);color:#fff;}
.card--purple .card-cta{background:var(--purple);color:#fff;}
.card--brown .card-cta{background:var(--brown);color:#fff;}
.card--teal .card-cta{background:var(--teal);color:#fff;}
.card--soon .card-cta{background:var(--border);color:var(--muted);cursor:default;}
.card-cta:not([disabled]):hover{opacity:.88;transform:translateX(2px);}
.card-cta svg{transition:transform .15s;}
.card-cta:not([disabled]):hover svg{transform:translateX(3px);}

/* ── FEATURES ── */
.features{background:var(--dark);padding:26px 40px;display:flex;justify-content:center;gap:52px;flex-wrap:wrap;margin-top:48px;}
.feature{display:flex;align-items:center;gap:10px;font-size:11px;letter-spacing:.1em;color:#888;text-transform:uppercase;}
.feature-dot{width:5px;height:5px;border-radius:50%;background:var(--gold);}

footer{text-align:center;padding:22px;font-size:11px;color:var(--muted);letter-spacing:.1em;border-top:1px solid var(--border);}
footer a{color:var(--muted);text-decoration:none;}
footer a:hover{color:var(--gold);}

@media(max-width:900px){.cards{grid-template-columns:repeat(2,1fr);}.cards-2col{grid-template-columns:1fr;}}
@media(max-width:600px){
  header{padding:12px 16px;}.brand{font-size:16px;}
  .hero{padding:44px 20px 36px;}.hero-sub{font-size:13px;}
  .cards,.cards-2col{grid-template-columns:1fr;padding:0 16px;gap:12px;}
  .section-title{padding:0 16px;}
  .card{padding:28px 20px 24px;}
  .card-title{font-size:22px;}
  .features{gap:24px;padding:20px 16px;}
}
</style>
</head>
